# FastAPI career-discovery API configuration (placeholders — no real secrets).

# Path to the ChromaDB store built by data/scripts/build_rag.py.
# Relative paths resolve against the repo root by default; override if you copied it.
CHROMA_PATH=../data/jobs/chroma
CHROMA_COLLECTION=job_ads

# Embedding model — MUST match the one used to build the store.
EMBED_MODEL=all-MiniLM-L6-v2

# How many job ads to retrieve per career field when scoring.
RAG_TOP_K=8

# Comma-separated frontend origins allowed by CORS.
CORS_ORIGINS=http://localhost:3000

API_PORT=8000
LOG_LEVEL=INFO
